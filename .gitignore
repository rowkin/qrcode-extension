# Node.js 标准忽略文件
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript 编译输出
*.tsbuildinfo
dist/

# 环境配置文件（敏感信息）
.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
*.log.*

# 系统文件
.DS_Store
Thumbs.db

# IDE/编辑器配置文件
.idea/
.vscode/
*.swp
*.swo
*.swn

# 临时文件
tmp/
temp/
*.tmp
*.temp

# Git 忽略文件
.git/
*.orig

# NPM 私有包相关
.npmrc

# 测试覆盖率输出
coverage/
*.lcov

# 包锁定文件（如果你不希望锁定文件被提交）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# 其他
manifest.json.backup
*.bak
screenshots/
build/
scripts/
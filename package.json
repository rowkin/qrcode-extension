{
  "name": "qrcode-extension",
  "version": "1.0.8",
  "description": "A simple and user-friendly Chrome extension for quickly generating QR codes from current page URLs, selected text, or links.",
  "main": "background.js",
  "scripts": {
    "clean": "git clean -df && git checkout -- .",
    "check-git": "node build/check-git-status.js",
    "build": "SRC_DIR=src bash ./scripts/bump_version.sh",
    "build:debug": "SRC_DIR=src bash -x ./scripts/bump_version.sh",
    "build:pack": "SRC_DIR=src bash ./scripts/bump_version.sh --pack-only",
    "build:pack:debug": "SRC_DIR=src bash -x ./scripts/bump_version.sh --pack-only",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:deploy:info": "node scripts/deploy-docs.js info",
    "docs:deploy:prepare": "node scripts/deploy-docs.js prepare",
    "docs:deploy:zip": "node scripts/deploy-docs.js zip",
    "docs:deploy:git": "node scripts/deploy-docs.js git",
    "docs:deploy:hook": "bash scripts/deploy-hook.sh",
    "docs:deploy:auto": "git push origin env_site && npm run docs:deploy:hook",
    "postinstall": "npm run check-node-version",
    "check-node-version": "node -e \"if (process.versions.node.split('.')[0] < 14) { console.error('Requires Node.js 14+'); process.exit(1); }\""
  },
  "keywords": [
    "chrome-extension",
    "qrcode",
    "url-to-qrcode",
    "text-to-qrcode",
    "chrome",
    "extension",
    "manifest-v3"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitee.com/mdsfe/qrcode-extension"
  },
  "author": "mdsfe",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "chalk": "^4.1.2",
    "clean-css": "^5.3.3",
    "html-minifier": "^4.0.0",
    "terser": "^5.39.0",
    "vitepress": "^1.0.0"
  }
}
